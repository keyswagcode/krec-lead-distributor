# ─────────────────────────────────────────────────────────────────────────
# KeyRealEstateCapital — environment configuration
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────

# GoHighLevel (LeadConnector) Private Integration token (starts with "pit-").
# Settings → Private Integrations → create a token with contacts + conversations scope.
GHL_API_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# GHL sub-account (location) ID. Defaults to the KREC location if unset.
GHL_LOCATION_ID=dJyVhiOEL3jUzPECFhIe

# Elementix MCP bearer token (Account → API / MCP access).
ELEMENTIX_BEARER_TOKEN=

# Elementix MCP endpoint (override only if self-hosting).
ELEMENTIX_MCP_URL=https://app.elementix.ai/api/mcp

# Optional: GHL custom-field ID holding a precomputed touchpoint count for a contact.
# If set, the bot reads this field instead of counting conversation messages (far cheaper).
# Leave blank to count outbound messages live.
GHL_TOUCHPOINT_FIELD_ID=

# Optional: GHL workflow ID to enroll each newly assigned cold lead into.
GHL_ENROLL_WORKFLOW_ID=
